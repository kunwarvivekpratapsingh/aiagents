# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── API Security ──────────────────────────────────────────────────────────────
# Long random string used for X-API-Key / Bearer token authentication.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to DISABLE authentication (local dev only).
API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use "*" for fully public APIs (cannot be combined with credentials).
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Session Memory ────────────────────────────────────────────────────────────
# How long (seconds) an idle session is kept in memory before eviction.
SESSION_TTL_SECONDS=3600

# Maximum number of concurrent sessions before LRU eviction kicks in.
MAX_SESSIONS=1000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Set to "false" to disable (not recommended in production).
RATE_LIMITING=true

# ── Model / Pipeline ──────────────────────────────────────────────────────────
MODEL=claude-sonnet-4-6
MAX_ITERATIONS=3
TOP_K=5
MAX_TOKENS=2048
CHUNK_SIZE=400
CHUNK_OVERLAP=60

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_DIR=./chroma_db
COLLECTION_NAME=agentic_rag_docs

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Set to "false" for human-readable logs in development.
JSON_LOGS=true

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
WORKERS=4
